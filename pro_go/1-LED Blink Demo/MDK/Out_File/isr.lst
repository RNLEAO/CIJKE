  455          void TM4_Isr() interrupt 20
  456          {
  457   1        
  458   1        
  459   1        
  460   1            
  461   1            //电感
  462   1            L   = read_adc_average(ADC_P06,5,ADC_12BIT);//1000
  463   1            LM  = read_adc_average(ADC_P00,5,ADC_12BIT);
  464   1            RM  = read_adc_average(ADC_P01,5,ADC_12BIT);//900
  465   1            R   = read_adc_average(ADC_P05,5,ADC_12BIT);
  466   1            MID = read_adc_average(ADC_P10,5,ADC_12BIT);//1200
  467   1      
  468   1            //限幅
  469   1            L   = limit_float(L,0,4000);
  470   1            LM  = limit_float(LM,0,4000);
  471   1            RM  = limit_float(RM,0,4000);
  472   1            R   = limit_float(R,0,4000);
  473   1            MID = limit_float(MID,0,4000);
  474   1            //归一化
  475   1            L   = normalize_float(L,0,4000);
  476   1            LM  = normalize_float(LM,0,4000);
  477   1            RM  = normalize_float(RM,0,4000);
  478   1            R   = normalize_float(R,0,4000);
  479   1            MID = normalize_float(MID,0,4000);
  480   1      
  481   1            
  482   1      
  483   1            R_raw=R;
  484   1            L_raw=L;
  485   1            
  486   1            
  487   1            
  488   1          /****************error***************//****************error***************//****************error*****
             -**********/
  489   1        
  490   1      
  491   1      
  492   1      
  493   1            error = (
  494   1                        err_H  * (L - R) + 
  495   1                        err_X  * (2.5*LM - 2.5*RM)
  496   1                     ) / (
  497   1                        err_HM * (L + R) + 
  498   1                        err_D  * fabs(LM - RM) + 
  499   1                        err_M  * MID
  500   1                     );
  501   1      
  502   1      //     error=0;
  503   1      
  504   1          /*********************方向环*********************//*********************方向环*******************
             -**//*********************方向环*********************/ 
  505   1          
  506   1      
  507   1          Turn_PID.err=error;
  508   1          //1 串级
C251 COMPILER V5.60.0,  isr                                                                24/06/25  17:23:52  PAGE 9   

  509   1          Turn_PID.out=Turn_PID.kp*Turn_PID.err+
  510   1                       Turn_PID.ki*Turn_PID.err*fabs(Turn_PID.err)*2+
  511   1                       Turn_PID.kd*(Turn_PID.err-Turn_PID.err_last)+
  512   1                       Turn_PID.kp1*gyro_data[0];
  513   1          Turn_PID.last=Turn_PID.out;
  514   1          //限幅
  515   1          Turn_PID.out=limit_function(Turn_PID.out,-dir_loop_limit,dir_loop_limit);
  516   1          
  517   1          Turn_PID.err_last=Turn_PID.err;
  518   1      
  519   1      
  520   1          TIM4_CLEAR_FLAG; //清除中断标志
  521   1      
  522   1      }
