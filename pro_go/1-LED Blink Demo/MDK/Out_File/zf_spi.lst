  121          uint8 spi_mosi(uint8 dat)
  122          {
  123   1          SPDAT = dat;          //DATAМФДцЦїИГжЕ
  124   1          while (!(SPSTAT & 0x80));     //ВщбЏЭъГЩБъжО
  125   1          SPSTAT = 0xc0;                  //ЧхжаЖЯБъжО
  126   1        return SPDAT;
