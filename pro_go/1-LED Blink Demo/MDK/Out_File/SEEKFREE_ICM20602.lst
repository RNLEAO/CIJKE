  518   2              case 0x10:
  519   2                  gyro_data = (float)gyro_value / 32.8f;
  520   2                  break;              // 0x10 ЭгТнвЧСПГЬЮЊ:ЁР1000dps     ЛёШЁЕНЕФЭгТнвЧЪ§ОнГ§вд 32.8          П
             -ЩвдзЊЛЏЮЊДјЮяРэЕЅЮЛЕФЪ§ОнЃЌЕЅЮЛЮЊЃКЁу/s
  521   2              case 0x18:
  522   2                  gyro_data = (float)gyro_value / 16.4f;
  523   2                  break;              // 0x18 ЭгТнвЧСПГЬЮЊ:ЁР2000dps     ЛёШЁЕНЕФЭгТнвЧЪ§ОнГ§вд 16.4          П
             -ЩвдзЊЛЏЮЊДјЮяРэЕЅЮЛЕФЪ§ОнЃЌЕЅЮЛЮЊЃКЁу/s
  524   2              default:
  525   2                  break;
  526   2          }
  527   1          return gyro_data;
  528   1      }
