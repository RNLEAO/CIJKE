               #define ICM20602_SCL_HIGH()         ICM20602_SCL_PIN = 1    //IOПкЪфГіИпЕчЦН
               
               #define ack 1      //жїгІД№
               #define no_ack 0   //ДггІД№ 
               
               //-------------------------------------------------------------------------------------------------------
             -------------
               //  @brief      ФЃФтIICбгЪБ
               //  @return     void
               //  @since      v1.0
               //  Sample usage:       ШчЙћIICЭЈбЖЪЇАмПЩвдГЂЪддіМгjЕФжЕ
               //-------------------------------------------------------------------------------------------------------
             -------------
               static void icm20602_simiic_delay(void)
               {
                   uint16 xdata j=ICM20602_SOFT_IIC_DELAY;
                   while(j--);
               }
               
               //ФкВПЪЙгУЃЌгУЛЇЮоашЕїгУ
               static void icm20602_simiic_start(void)
               {
                   ICM20602_SDA_HIGH();
                   ICM20602_SCL_HIGH();
                   icm20602_simiic_delay();
                   ICM20602_SDA_LOW();
                   icm20602_simiic_delay();
                   ICM20602_SCL_LOW();
               }
               
               //ФкВПЪЙгУЃЌгУЛЇЮоашЕїгУ
               static void icm20602_simiic_stop(void)
               {
                   ICM20602_SDA_LOW();
                   ICM20602_SCL_LOW();
                   icm20602_simiic_delay();
                   ICM20602_SCL_HIGH();
                   icm20602_simiic_delay();
                   ICM20602_SDA_HIGH();
                   icm20602_simiic_delay();
               }
               
               //жїгІД№(АќКЌack:SDA=0КЭno_ack:SDA=0)
               //ФкВПЪЙгУЃЌгУЛЇЮоашЕїгУ
               static void icm20602_simiic_sendack(unsigned char ack_dat)
               {
                   ICM20602_SCL_LOW();
                   icm20602_simiic_delay();
                   if(ack_dat) ICM20602_SDA_LOW();
                   else      ICM20602_SDA_HIGH();
                   ICM20602_SCL_HIGH();
                   icm20602_simiic_delay();
                   ICM20602_SCL_LOW();
                   icm20602_simiic_delay();
               }
               
               
               static int icm20602_sccb_waitack(void)
               {
                   ICM20602_SCL_LOW();
                   icm20602_simiic_delay();
                   ICM20602_SCL_HIGH();
                   icm20602_simiic_delay();
                   if(GET_ICM20602_SDA)           //гІД№ЮЊИпЕчЦНЃЌвьГЃЃЌЭЈаХЪЇАм
                   {
                       ICM20602_SCL_LOW();
C251 COMPILER V5.60.0,  SEEKFREE_ICM20602                                                  31/03/25  21:11:31  PAGE 3   

                       return 0;
                   }
                   ICM20602_SCL_LOW();
                   icm20602_simiic_delay();
                   return 1;
               }
               
               //зжНкЗЂЫЭГЬађ
               //ЗЂЫЭc(ПЩвдЪЧЪ§ОнвВПЩЪЧЕижЗ)ЃЌЫЭЭъКѓНгЪеДггІД№
               //ВЛПМТЧДггІД№ЮЛ
               //ФкВПЪЙгУЃЌгУЛЇЮоашЕїгУ
               static void icm20602_send_ch(uint8 c)
               {
                   uint8 xdata i = 8;
                   while(i--)
                   {
                       if(c & 0x80)  ICM20602_SDA_HIGH();//SDA ЪфГіЪ§Он
                       else      ICM20602_SDA_LOW();
                       c <<= 1;
                       icm20602_simiic_delay();
                       ICM20602_SCL_HIGH();                //SCL Р­ИпЃЌВЩМЏаХКХ
                       icm20602_simiic_delay();
                       ICM20602_SCL_LOW();                //SCL ЪБжгЯпР­ЕЭ
                   }
                   icm20602_sccb_waitack();
               }
               
               
               //зжНкНгЪеГЬађ
               //НгЪеЦїМўДЋРДЕФЪ§ОнЃЌДЫГЬађгІХфКЯ|жїгІД№КЏЪ§|ЪЙгУ
               //ФкВПЪЙгУЃЌгУЛЇЮоашЕїгУ
               static uint8 icm20602_read_ch(uint8 ack_x)
               {
                   uint8 xdata i;
                   uint8 xdata c;
                   c=0;
                   ICM20602_SCL_LOW();
                   icm20602_simiic_delay();
                   ICM20602_SDA_HIGH();
                   for(i=0; i<8; i++)
                   {
                       icm20602_simiic_delay();
                       ICM20602_SCL_LOW();         //жУЪБжгЯпЮЊЕЭЃЌзМБИНгЪеЪ§ОнЮЛ
                       icm20602_simiic_delay();
                       ICM20602_SCL_HIGH();         //жУЪБжгЯпЮЊИпЃЌЪЙЪ§ОнЯпЩЯЪ§ОнгааЇ
                       icm20602_simiic_delay();
                       c<<=1;
                       if(GET_ICM20602_SDA)
                       {
                           c+=1;   //ЖСЪ§ОнЮЛЃЌНЋНгЪеЕФЪ§ОнДцc
                       }
                   }
                   ICM20602_SCL_LOW();
                   icm20602_simiic_delay();
                   icm20602_simiic_sendack(ack_x);
                   return c;
               }
               
               
               //-------------------------------------------------------------------------------------------------------
             -------------
               //  @brief      ФЃФтIICаДЪ§ОнЕНЩшБИМФДцЦїКЏЪ§
               //  @param      dev_add     ЩшБИЕижЗ(ЕЭЦпЮЛЕижЗ)
               //  @param      reg       МФДцЦїЕижЗ
               //  @param      dat       аДШыЕФЪ§Он
               //  @return     void
C251 COMPILER V5.60.0,  SEEKFREE_ICM20602                                                  31/03/25  21:11:31  PAGE 4   

               //  @since      v1.0
               //  Sample usage:
               //-------------------------------------------------------------------------------------------------------
             -------------
               static void icm20602_simiic_write_reg(uint8 dev_add, uint8 reg, uint8 dat)
               {
                   icm20602_simiic_start();
                   icm20602_send_ch( (dev_add<<1) | 0x00);   //ЗЂЫЭЦїМўЕижЗМгаДЮЛ
                   icm20602_send_ch( reg );           //ЗЂЫЭДгЛњМФДцЦїЕижЗ
                   icm20602_send_ch( dat );           //ЗЂЫЭашвЊаДШыЕФЪ§Он
                   icm20602_simiic_stop();
               }
               
               //-------------------------------------------------------------------------------------------------------
             -------------
               //  @brief      ФЃФтIICДгЩшБИМФДцЦїЖСШЁЪ§Он
               //  @param      dev_add     ЩшБИЕижЗ(ЕЭЦпЮЛЕижЗ)
               //  @param      reg       МФДцЦїЕижЗ
               //  @param      type      бЁдёЭЈаХЗНЪНЪЧIIC  ЛЙЪЧ SCCB
               //  @return     uint8 xdata     ЗЕЛиМФДцЦїЕФЪ§Он
               //  @since      v1.0
               //  Sample usage:
               //-------------------------------------------------------------------------------------------------------
             -------------
               static uint8 icm20602_simiic_read_reg(uint8 dev_add, uint8 reg)
               {
                   uint8 xdata dat;
                   icm20602_simiic_start();
                   icm20602_send_ch( (dev_add<<1) | 0x00);  //ЗЂЫЭЦїМўЕижЗМгаДЮЛ
                   icm20602_send_ch( reg );          //ЗЂЫЭДгЛњМФДцЦїЕижЗ
                   icm20602_simiic_start();
                   icm20602_send_ch( (dev_add<<1) | 0x01);  //ЗЂЫЭЦїМўЕижЗМгЖСЮЛ
                   dat = icm20602_read_ch(no_ack);           //ЖСШЁЪ§Он
                   icm20602_simiic_stop();
                   return dat;
               }
               
               //-------------------------------------------------------------------------------------------------------
             -------------
               //  @brief      ФЃФтIICЖСШЁЖрзжНкЪ§Он
               //  @param      dev_add     ЩшБИЕижЗ(ЕЭЦпЮЛЕижЗ)
               //  @param      reg       МФДцЦїЕижЗ
               //  @param      dat_add     Ъ§ОнБЃДцЕФЕижЗжИеы
               //  @param      num       ЖСШЁзжНкЪ§СП
               //  @param      type      бЁдёЭЈаХЗНЪНЪЧIIC  ЛЙЪЧ SCCB
               //  @return     uint8 xdata     ЗЕЛиМФДцЦїЕФЪ§Он
               //  @since      v1.0
               //  Sample usage:
               //-------------------------------------------------------------------------------------------------------
             -------------
               static void icm20602_simiic_read_regs(uint8 dev_add, uint8 reg, uint8 *dat_add, uint32 num)
               {
                   icm20602_simiic_start();
                   icm20602_send_ch( (dev_add<<1) | 0x00);  //ЗЂЫЭЦїМўЕижЗМгаДЮЛ
                   icm20602_send_ch( reg );          //ЗЂЫЭДгЛњМФДцЦїЕижЗ
                   icm20602_simiic_start();
                   icm20602_send_ch( (dev_add<<1) | 0x01);  //ЗЂЫЭЦїМўЕижЗМгЖСЮЛ
                   while(--num)
                   {
                       *dat_add = icm20602_read_ch(ack); //ЖСШЁЪ§Он
                       dat_add++;
                   }
                   *dat_add = icm20602_read_ch(no_ack); //ЖСШЁЪ§Он
                   icm20602_simiic_stop();
               }
               
