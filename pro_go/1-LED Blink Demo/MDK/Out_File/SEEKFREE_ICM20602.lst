             -ПЩвдзЊЛЏЮЊДјЮяРэЕЅЮЛЕФЪ§ОнЃЌЕЅЮЛЃКg(m/s^2)
  485   2              case 0x08:
  486   2                  acc_data = (float)acc_value / 8192;
  487   2                  break;                  // 0x08 МгЫйЖШМЦСПГЬЮЊ:ЁР4g     ЛёШЁЕНЕФМгЫйЖШМЦЪ§Он Г§вд 8192       
             -ПЩвдзЊЛЏЮЊДјЮяРэЕЅЮЛЕФЪ§ОнЃЌЕЅЮЛЃКg(m/s^2)
  488   2              case 0x10:
  489   2                  acc_data = (float)acc_value / 4096;
  490   2                  break;                  // 0x10 МгЫйЖШМЦСПГЬЮЊ:ЁР8g     ЛёШЁЕНЕФМгЫйЖШМЦЪ§Он Г§вд 4096       
             -ПЩвдзЊЛЏЮЊДјЮяРэЕЅЮЛЕФЪ§ОнЃЌЕЅЮЛЃКg(m/s^2)
  491   2              case 0x18:
  492   2                  acc_data = (float)acc_value / 2048;
  493   2                  break;                  // 0x18 МгЫйЖШМЦСПГЬЮЊ:ЁР16g    ЛёШЁЕНЕФМгЫйЖШМЦЪ§Он Г§вд 2048       
             -ПЩвдзЊЛЏЮЊДјЮяРэЕЅЮЛЕФЪ§ОнЃЌЕЅЮЛЃКg(m/s^2)
  494   2              default:
  495   2                  break;
  496   2          }
  497   1          return acc_data;
  498   1      }
