  264          static uint8 icm20602_simspi_wr_byte(uint8 byte)
  265          {
  266   1          uint8 xdata i;
  267   1          for(i=0; i<8; i++)
  268   1          {
  269   2              ICM20602_MOSI(byte&0x80);
  270   2              byte <<= 1;
  271   2              ICM20602_SCK (0);
  272   2              ICM20602_SCK (0);
  273   2              ICM20602_SCK (1);
  274   2              ICM20602_SCK (1);
  275   2              byte |= ICM20602_MISO;
  276   2          }
  277   1          return(byte);
  278   1      }
