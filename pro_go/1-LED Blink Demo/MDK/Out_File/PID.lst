   11          /**************************************************************************
   12          函数名称：增量式PID控制器
   13          功能描述：计算增量式PID控制输出
   14          输入参数：Encoder - 当前编码器值
   15                    Target - 目标值
   16                    sptr - PID控制器结构体指针
   17          返回值：PID控制输出值
   18          **************************************************************************/
   19          float IncPID(float Encoder, float Target, _PID* sptr) 
   20          {
   21   1          float delta_pwm; // PWM增量值
   22   1          
   23   1          // 1. 更新当前值和目标值
   24   1          sptr->now = Encoder; 
   25   1          sptr->Target = Target; 
   26   1          
   27   1          // 2. 计算当前误差
   28   1          sptr->err = sptr->Target - sptr->now; 
   29   1          
   30   1          // 3. 计算PID各项输出
   31   1          // 比例项
   32   1          sptr->kp_out = sptr->kp * (sptr->err - sptr->err_last);
   33   1          // 积分项
   34   1          sptr->ki_out = sptr->ki * sptr->err;
   35   1          // 微分项
   36   1          sptr->kd_out = sptr->kd * (sptr->err - 2 * sptr->err_last + sptr->d_err);
   37   1          
   38   1          // 4. 计算总PID输出
   39   1          delta_pwm = sptr->kp_out + sptr->ki_out + sptr->kd_out;
   40   1      
   41   1          // 5. 更新历史误差值
   42   1          sptr->d_err = sptr->err_last; // 保存上上次误差
   43   1          sptr->err_last = sptr->err;   // 保存上次误差
   44   1          // 6. 返回PWM增量值
   45   1          return delta_pwm; 
   46   1      }
