  151          
  152          float turn_PstPID(float turn_error,_PID* sptr)
  153          {
  154   1          float delta_output;
  155   1      
  156   1          /* 更新当前误差 */
  157   1          sptr->err = turn_error;
  158   1      
  159   1          /* 非线性增强型增量 PID 计算 */
  160   1          delta_output = sptr->kp * (sptr->err - sptr->err_last)
  161   1                       + sptr->ki * sptr->err
  162   1                       + sptr->kd * sptr->err * fabs(sptr->err)
  163   1                       + sptr->kd2 * sptr->err * sptr->err * sptr->err;
  164   1      
  165   1          /* 叠加输出 */
  166   1          sptr->out += delta_output;
  167   1      
  168   1          /* 输出限幅 */
  169   1          if (sptr->out > sptr->limit_max)
  170   1              sptr->out = sptr->limit_max;
  171   1          else if (sptr->out < sptr->limit_min)
  172   1              sptr->out = sptr->limit_min;
  173   1      
  174   1          /* 误差历史更新 */
  175   1          sptr->err_last = sptr->err;
  176   1      
  177   1          return sptr->out;
  178   1      }
