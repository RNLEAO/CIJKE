   95          // 简单一阶低通滤波器，滤掉gyro_data[0]噪声
   96          float gyro_lowpass_filter(float new_value, float old_value, float alpha)
   97          {
   98   1          // alpha 越小滤波越强（典型 0.1 ~ 0.3）
   99   1          return alpha * new_value + (1.0f - alpha) * old_value;
  100   1      }
