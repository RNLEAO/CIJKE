   47          
   48          /**************************************************************************
   49          函数名称：位置式PID控制器
   50          功能描述：计算位置式PID控制输出
   51          输入参数：Encoder - 当前编码器值
   52                    Target - 目标值
   53                    sptr - PID控制器结构体指针
   54          返回值：PID控制输出值
   55          **************************************************************************/
   56          float PositionPID(float Encoder, float Target, _PID* sptr)
C251 COMPILER V5.60.0,  PID                                                                06/07/26  15:12:38  PAGE 2   

   57          {
   58   1          // 1. 更新当前值和目标值
   59   1          sptr->now = Encoder;
   60   1          sptr->Target = Target;
   61   1      
   62   1          // 2. 计算当前误差
   63   1          sptr->err = sptr->Target - sptr->now;
   64   1      
   65   1          // 3. 更新积分项
   66   1          // 累加当前误差，同时考虑积分限幅
   67   1          sptr->err_sum += sptr->err;
   68   1        
   69   1          // 积分限幅设置为-100到100，可调整
   70   1          if (sptr->err_sum > 100.0f) 
   71   1              sptr->err_sum = 100.0f;
   72   1          else if (sptr->err_sum < -100.0f) 
   73   1              sptr->err_sum = -100.0f;
   74   1      
   75   1          // 4. 计算PID各项输出
   76   1          // 比例项
   77   1          sptr->kp_out = sptr->kp * sptr->err;
   78   1          // 积分项
   79   1          sptr->ki_out = sptr->ki * sptr->err_sum;
   80   1          // 微分项
   81   1          sptr->kd_out = sptr->kd * (sptr->err - sptr->err_last);
   82   1      
   83   1          // 5. 计算总PID输出
   84   1          sptr->out = sptr->kp_out + sptr->ki_out + sptr->kd_out;
   85   1      
   86   1          // 6. 保存历史误差
   87   1          sptr->err_last = sptr->err;
   88   1      
   89   1          // 7. 返回控制输出值
   90   1          return sptr->out;
   91   1      }
