   10          /**************************************************************************
   11          函数名称：增量式PID控制器
   12          功能描述：计算增量式PID控制输出
   13          输入参数：Encoder - 当前编码器值
   14                    Target - 目标值
   15                    sptr - PID控制器结构体指针
   16          返回值：PID控制输出值
   17          **************************************************************************/
   18          float IncPID(float Encoder, float Target, _PID* sptr) 
   19          {
   20   1          float delta_pwm; // PWM增量值
   21   1          
   22   1          // 1. 更新当前值和目标值
   23   1          sptr->now = Encoder; 
   24   1          sptr->Target = Target; 
   25   1          
   26   1          // 2. 计算当前误差
   27   1          sptr->err = sptr->Target - sptr->now; 
   28   1          
   29   1          // 3. 计算PID各项输出
   30   1          // 比例项
   31   1          sptr->kp_out = sptr->kp * (sptr->err - sptr->err_last);
   32   1          // 积分项
   33   1          sptr->ki_out = sptr->ki * sptr->err;
   34   1          // 微分项
   35   1          sptr->kd_out = sptr->kd * (sptr->err - 2 * sptr->err_last + sptr->d_err);
   36   1          
   37   1          // 4. 计算总PID输出
   38   1          delta_pwm = sptr->kp_out + sptr->ki_out + sptr->kd_out;
   39   1      
   40   1          // 5. 更新历史误差值
   41   1          sptr->d_err = sptr->err_last; // 保存上上次误差
   42   1          sptr->err_last = sptr->err;   // 保存上次误差
   43   1          // 6. 返回PWM增量值
   44   1          return delta_pwm; 
   45   1      }
