  103          float GyroPositionPID(float gyro_now_raw, float Target, _PID* sptr)
  104          {
  105   1          static float gyro_filtered = 0.0f;  // 滤波后的陀螺仪值，保持状态
  106   1          float deadzone= 0.0f;  
  107   1        
  108   1        
  109   1          // 1️⃣ 滤波陀螺仪数据
  110   1          gyro_filtered = gyro_lowpass_filter(gyro_now_raw, gyro_filtered, 0.2f);  // alpha = 0.2，可调
  111   1      
  112   1          // 2️⃣ 更新当前值和目标值
  113   1          sptr->now = gyro_filtered;
  114   1          sptr->Target = Target;
  115   1      
  116   1          // 3️⃣ 计算当前误差
  117   1          sptr->err = sptr->Target - sptr->now;
  118   1      
  119   1          // 4️⃣ 死区处理（防止噪声误触发）
  120   1          deadzone = 1.0f;  // 1 deg/s 死区
  121   1          if (fabs(sptr->err) < deadzone)
  122   1          {
C251 COMPILER V5.60.0,  PID                                                                24/06/25  15:45:11  PAGE 3   

  123   2              sptr->err = 0.0f;
  124   2          }
  125   1      
  126   1          // 5️⃣ 更新积分项
  127   1          sptr->err_sum += sptr->err;
  128   1          // 积分限幅
  129   1          if (sptr->err_sum > 50.0f) 
  130   1              sptr->err_sum = 50.0f;
  131   1          else if (sptr->err_sum < -50.0f) 
  132   1              sptr->err_sum = -50.0f;
  133   1      
  134   1          // 6️⃣ 计算PID各项输出
  135   1          sptr->kp_out = sptr->kp * sptr->err;
  136   1          sptr->ki_out = sptr->ki * sptr->err_sum;
  137   1          sptr->kd_out = sptr->kd * (sptr->err - sptr->err_last);
  138   1      
