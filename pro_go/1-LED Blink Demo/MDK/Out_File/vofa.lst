   79   1          {
   80   2              data_Start_Num += 1; // 后移一位到数据位
   81   2              minus_Flag = 1; // 负数flag
   82   2          }
   83   1          data_Num = data_End_Num - data_Start_Num + 1;
   84   1          if(data_Num == 4) // 数据共4位
   85   1          {
   86   2              data_return = (DataBuff[data_Start_Num]-48)  + (DataBuff[data_Start_Num+2]-48)*0.1f +
   87   2                      (DataBuff[data_Start_Num+3]-48)*0.01f;
   88   2          }
   89   1          else if(data_Num == 5) // 数据共5位
   90   1          {
   91   2              data_return = (DataBuff[data_Start_Num]-48)*10 + (DataBuff[data_Start_Num+1]-48) + (DataBuff[data
             -_Start_Num+3]-48)*0.1f +
   92   2                      (DataBuff[data_Start_Num+4]-48)*0.01f;
   93   2          }
   94   1          else if(data_Num == 6) // 数据共6位
   95   1          {
   96   2              data_return = (DataBuff[data_Start_Num]-48)*100 + (DataBuff[data_Start_Num+1]-48)*10 + (DataBuff[
             -data_Start_Num+2]-48) +
   97   2                      (DataBuff[data_Start_Num+4]-48)*0.1f + (DataBuff[data_Start_Num+5]-48)*0.01f;
   98   2          }
   99   1          if(minus_Flag == 1)  data_return = -data_return;
  100   1          return data_return;
  101   1      }
