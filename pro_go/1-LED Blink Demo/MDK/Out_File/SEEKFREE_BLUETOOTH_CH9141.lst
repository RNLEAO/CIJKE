   86          uint32 bluetooth_ch9141_send_buff (uint8 *buff, uint32 len)
   87          {
   88   1          uint16 xdata time_count = 0;
   89   1          while(len > 30)
   90   1          {
   91   2              time_count = 0;
   92   2              while(BLUETOOTH_CH9141_RTS_PIN && time_count++ < BLUETOOTH_CH9141_TIMEOUT_COUNT)  // ШчЙћRTSЮЊЕЭЕ
             -чЦНЃЌдђМЬајЗЂЫЭЪ§Он
   93   2                  delay_ms(1);
   94   2              if(time_count >= BLUETOOTH_CH9141_TIMEOUT_COUNT)
   95   2                  return len;                                                         // ФЃПщУІ,ШчЙћдЪаэЕБЧАГЬа
             -ђЪЙгУwhileЕШД§ дђПЩвдЪЙгУКѓУцзЂЪЭЕФwhileЕШД§гяОфЬцЛЛБОifгяОф
   96   2              uart_putbuff(BLUETOOTH_CH9141_INDEX, buff, 30);
   97   2              buff += 30;                                                             // ЕижЗЦЋвЦ
   98   2              len -= 30;                                                              // Ъ§СП
   99   2          }
  100   1          time_count = 0;
  101   1          while(BLUETOOTH_CH9141_RTS_PIN && time_count++ < BLUETOOTH_CH9141_TIMEOUT_COUNT)      // ШчЙћRTSЮЊЕЭЕ
             -чЦНЃЌдђМЬајЗЂЫЭЪ§Он
  102   1              delay_ms(1);
  103   1          if(time_count >= BLUETOOTH_CH9141_TIMEOUT_COUNT)
  104   1              return len;                                                             // ФЃПщУІ,ШчЙћдЪаэЕБЧАГЬа
             -ђЪЙгУwhileЕШД§ дђПЩвдЪЙгУКѓУцзЂЪЭЕФwhileЕШД§гяОфЬцЛЛБОifгяОф
  105   1          uart_putbuff(BLUETOOTH_CH9141_INDEX, buff, (uint16)len);                            // ЗЂЫЭзюКѓЕФЪ§Он
  106   1          return 0;
  107   1      }
