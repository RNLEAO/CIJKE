  524           * - 如果 MID >= 60, 速度为 380.
  525           * - 否则, 速度按二次函数插值。
  526           * 具体地, 使用 (归一化MID比例)^2 的方式来实现加速上升效果。
  527           *
  528           * @param current_mid_value 当前中间电感传感器的读数。
  529           * @return 计算得到的目标速度。
  530           */
  531          float calculate_dynamic_target_speed_quadratic(float current_mid_value) {
  532   1          #if 1
  533   1          const int MID_min_threshold = 26;   // 修改：原为 28
  534   1          const int speed_at_MID_min = 230;
  535   1          const int MID_max_threshold = 30;   // 修改：原为 60
  536   1          const int speed_at_MID_max = 330;
  537   1      
  538   1          int calculated_speed;
  539   1      
  540   1          if (current_mid_value <= MID_min_threshold) {
  541   2              calculated_speed = speed_at_MID_min;
  542   2          } else if (current_mid_value >= MID_max_threshold) {
  543   2              calculated_speed = speed_at_MID_max;
  544   2          } else {
  545   2              // 1. 归一化 MID 值到 0~1
  546   2              float mid_ratio = (current_mid_value - (float)MID_min_threshold) / 
  547   2                                ((float)MID_max_threshold - (float)MID_min_threshold);
  548   2              
  549   2              // 2. 使用四次函数加速因子
  550   2              float quartic_factor = mid_ratio * mid_ratio * mid_ratio * mid_ratio;           // mid_ratio^4
  551   2              
  552   2              // 3. 计算目标速度
  553   2              float speed_range = (float)(speed_at_MID_max - speed_at_MID_min);
  554   2              calculated_speed = (int)((float)speed_at_MID_min + quartic_factor * speed_range);
  555   2          }
  556   1      
  557   1          return calculated_speed;
  558   1          
  559   1          #endif
  560   1          
  561   1          
  562   1      }
