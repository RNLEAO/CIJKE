  604          /**
  605           * @brief 根据中间电感值 (MID) 计算动态目标速度，呈二次函数型加速上升。
  606           *
  607           * 速度从270 (当 MID=28 时) 以二次曲线方式增加到 380 (当 MID=60 时)。
  608           * - 如果 MID <= 28, 速度为 270.
  609           * - 如果 MID >= 60, 速度为 380.
  610           * - 否则, 速度按二次函数插值。
  611           * 具体地, 使用 (归一化MID比例)^2 的方式来实现加速上升效果。
  612           *
  613           * @param current_mid_value 当前中间电感传感器的读数。
  614           * @return 计算得到的目标速度。
  615           */
  616          float calculate_dynamic_target_speed_quadratic(float current_mid_value) {
  617   1          #if 1
  618   1          const int MID_min_threshold = 15;   // 修改：原为 28
  619   1          const int speed_at_MID_min = 120;
  620   1          const int MID_max_threshold = 25;   // 修改：原为 60
  621   1          const int speed_at_MID_max = 320;
  622   1      
  623   1          int calculated_speed;
  624   1      
  625   1          if (current_mid_value <= MID_min_threshold) {
  626   2              calculated_speed = speed_at_MID_min;
  627   2          } else if (current_mid_value >= MID_max_threshold) {
  628   2              calculated_speed = speed_at_MID_max;
  629   2          } else {
  630   2              // 1. 归一化 MID 值到 0~1
  631   2              float mid_ratio = (current_mid_value - (float)MID_min_threshold) / 
  632   2                                ((float)MID_max_threshold - (float)MID_min_threshold);
  633   2              
  634   2              // 2. 使用四次函数加速因子
  635   2              float quartic_factor = mid_ratio * mid_ratio * mid_ratio * mid_ratio;           // mid_ratio^4
  636   2              
  637   2              // 3. 计算目标速度
  638   2              float speed_range = (float)(speed_at_MID_max - speed_at_MID_min);
  639   2              calculated_speed = (int)((float)speed_at_MID_min + quartic_factor * speed_range);
  640   2          }
  641   1      
